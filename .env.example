# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------

# Required
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_group_chat_id_here

# Optional
OPENAI_API_KEY=your_openai_api_key_here
PORTAL_URL=http://localhost:8000


# ---------------------------------------------------------------------------
# Directors Portal (NUS Email 2-Step Verification)
# ---------------------------------------------------------------------------

# Required
JWT_SECRET=replace_with_random_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender_account@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=your_sender_account@gmail.com
SMTP_USE_TLS=true

# Optional
DB_PATH=capt_pedia.db
PORTAL_PORT=8000
SECURE_COOKIES=false
ALLOWED_EMAIL_DOMAINS=u.nus.edu
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
